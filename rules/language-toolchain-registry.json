{
  "version": 2,
  "languages": {
    "evm": {
      "build_command": "forge build",
      "test_command": "forge test --match-test test_{ID} -vvv",
      "test_filter_mode": "match_test_regex",
      "fuzz_engines": [
        {
          "name": "foundry_fuzz",
          "command": "forge test --match-test testFuzz_{ID} -vvv",
          "template": "function testFuzz_{ID}(uint256 x) public { x = bound(x, MIN, MAX); ... }",
          "notes": "use bound() to constrain inputs; randomized; runs default 256 iterations"
        },
        {
          "name": "medusa_stateful",
          "command": "medusa fuzz",
          "template_path": "prompts/evm/phase4b-medusa-fuzz.md",
          "output_file": "medusa_findings.md",
          "notes": "stateful fuzzer; runs invariant properties from properties.sol"
        }
      ],
      "static_analyzers": [
        {"name": "slither", "command": "slither .", "primary": true},
        {"name": "aderyn", "command": "aderyn .", "primary": false, "role": "slither_fallback"}
      ],
      "alt_build": {
        "hardhat": {
          "build_command": "npx hardhat compile",
          "test_command": "npx hardhat test --grep \"{ID}\"",
          "fuzz_engines": [],
          "notes": "hardhat-only projects skip the fuzz variant"
        }
      },
      "fork_testing": "forge test --match-test test_{ID} --fork-url {RPC_URL} -vvv",
      "evidence_tags": ["POC-PASS", "POC-FAIL", "MEDUSA-PASS", "CODE-TRACE"],
      "docs_sources": [
        "https://book.getfoundry.sh/",
        "https://secure-contracts.com/program-analysis/medusa/"
      ]
    },
    "solana": {
      "build_command": "cargo build-sbf",
      "alt_build": {
        "anchor": {
          "build_command": "anchor build",
          "notes": "preferred when Anchor.toml is present"
        }
      },
      "test_command": "cargo test test_{id} -- --nocapture",
      "test_filter_mode": "cargo_name_filter",
      "fuzz_engines": [
        {
          "name": "trident",
          "command": "cd trident-tests && trident fuzz run fuzz_0",
          "template": "Trident's IDL-driven handler in trident-tests/fuzz_instructions.rs",
          "detection_flag": "trident_available",
          "notes": "v0.11+ uses built-in TridentSVM (no honggfuzz). Anchor-only; needs `trident init`",
          "docs": "https://ackee.xyz/trident/docs/"
        },
        {
          "name": "proptest",
          "command": "cargo test test_fuzz_{id}",
          "template": "proptest! { #[test] fn test_fuzz_{id}(x in 1u64..MAX) { ... } }",
          "notes": "fallback when Trident unavailable or for native (non-Anchor) programs"
        }
      ],
      "static_analyzers": [
        {"name": "scout-audit", "command": "cargo scout-audit", "primary": true, "notes": "post-2025 successor; superset of soroban-scout for Anchor"}
      ],
      "fallback_strategy": "proptest with bounded inputs, then boundary-value parameterized tests",
      "evidence_tags": ["POC-PASS", "POC-FAIL", "FUZZ-PASS", "CODE-TRACE"],
      "docs_sources": [
        "https://solana.com/docs/programs/testing",
        "https://www.anchor-lang.com/docs/testing"
      ]
    },
    "aptos": {
      "build_command": "aptos move compile",
      "test_command": "aptos move test --filter test_{id}",
      "test_filter_mode": "filter_substring",
      "fuzz_engines": [],
      "fallback_strategy": "boundary-value parameterized tests — write multiple #[test] functions covering min, mid, MAX_U64 for each input (no built-in fuzzer)",
      "static_analyzers": [
        {"name": "move-prover", "command": "aptos move prove", "primary": false, "notes": "requires #[spec] annotations; opt-in"}
      ],
      "evidence_tags": ["POC-PASS", "POC-FAIL", "CODE-TRACE"],
      "docs_sources": [
        "https://aptos.dev/build/smart-contracts/book/unit-testing",
        "https://aptos.dev/build/smart-contracts/prover"
      ]
    },
    "sui": {
      "build_command": "sui move build",
      "test_command": "sui move test {test_name}",
      "test_filter_mode": "positional_filter",
      "fuzz_engines": [
        {
          "name": "move_random_test",
          "command": "sui move test --rand-num-iters {iters} {test_name}",
          "template": "#[random_test]"
        }
      ],
      "fallback_strategy": "boundary-value parameterized tests when random-input tests cannot compile",
      "evidence_tags": ["POC-PASS", "POC-FAIL", "CODE-TRACE"],
      "docs_sources": [
        "https://move-book.com/testing/testing-basics",
        "https://move-book.com/testing/random-test/"
      ]
    },
    "soroban": {
      "build_command": "stellar contract build",
      "test_command": "cargo test --features testutils test_{id}",
      "test_filter_mode": "cargo_name_filter",
      "fuzz_engines": [
        {
          "name": "cargo_fuzz",
          "command": "cargo +nightly fuzz run fuzz_{id}",
          "template_path": "prompts/soroban/phase4b-invariant-fuzz.md",
          "output_file": "cargo_fuzz_findings.md"
        },
        {
          "name": "proptest",
          "command": "cargo test --features testutils proptest_{id}",
          "output_file": "proptest_findings.md"
        }
      ],
      "fallback_strategy": "proptest with bounded inputs or boundary-value parameterized tests",
      "evidence_tags": ["POC-PASS", "POC-FAIL", "FUZZ-PASS", "CODE-TRACE"],
      "docs_sources": ["https://developers.stellar.org/docs/build/smart-contracts"]
    }
  }
}
