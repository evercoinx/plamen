{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Write(*)",
      "Edit(*)",
      "Agent(*)",
      "NotebookEdit(*)",
      "WebSearch",
      "WebFetch(*)",
      "Task(*)",
      "ToolSearch(*)",
      "mcp__slither-analyzer__*",
      "mcp__unified-vuln-db__*",
      "mcp__solana-fender__*",
      "mcp__farofino__*",
      "mcp__tavily-search__*",
      "mcp__evm-chain-data__*",
      "mcp__foundry-suite__*",
      "mcp__helius__*"
    ],
    "deny": [
      "Bash(rm -rf /)*",
      "Bash(rm -rf ~)*",
      "Bash(rm -rf .)*",
      "Bash(sudo *)",
      "Bash(curl * | bash*)",
      "Bash(curl * | sh*)",
      "Bash(wget * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(format *)",
      "Bash(diskpart*)",
      "Bash(shutdown*)",
      "Bash(taskkill /f /im*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "env": {
    "MCP_TIMEOUT": "30000",
    "MCP_TOOL_TIMEOUT": "300000",
    "SOLODIT_API_KEY": ""
  },
  "hooks": {},
  "mcpServers": {
    "slither-analyzer": {
      "command": "slither-mcp",
      "args": [],
      "_comment": "EVM static analysis. Installed from custom-mcp/slither-mcp via plamen install. If not in PATH, replace with full path from: which slither-mcp (macOS/Linux) or where slither-mcp (Windows)"
    },
    "solana-fender": {
      "command": "python",
      "args": ["-m", "solana_fender_mcp"],
      "cwd": "./custom-mcp/solana-fender",
      "_comment": "Optional: Solana program security analysis"
    },
    "unified-vuln-db": {
      "command": "python",
      "args": ["-m", "unified_vuln.server"],
      "cwd": "./custom-mcp/unified-vuln-db",
      "_comment": "MCP server for vulnerability research. RAG database is optional — run 'plamen rag' to populate (pipeline works without it)"
    },
    "farofino": {
      "command": "python",
      "args": ["-m", "farofino_mcp"],
      "cwd": "./custom-mcp/farofino-mcp",
      "_comment": "Optional: Solidity static analysis fallback"
    },
    "foundry-suite": {
      "command": "npx",
      "args": ["-y", "@pranesh.asp/foundry-mcp-server@0.1.5"],
      "env": {
        "RPC_URL": "YOUR_RPC_URL"
      },
      "_comment": "Optional: EVM fork testing. Get RPC from Alchemy/Infura/public endpoints"
    },
    "evm-chain-data": {
      "command": "npx",
      "args": ["-y", "@mcpdotdirect/evm-mcp-server@2.0.4"],
      "env": {
        "ETHERSCAN_API_KEY": "YOUR_ETHERSCAN_API_KEY"
      },
      "_comment": "Optional: On-chain contract verification. Free key: https://etherscan.io/apis"
    },
    "tavily-search": {
      "command": "npx",
      "args": ["-y", "tavily-mcp@0.2.18"],
      "env": {
        "TAVILY_API_KEY": "YOUR_TAVILY_API_KEY"
      },
      "_comment": "Optional: Web search for fork ancestry + doc lookup. Key: https://tavily.com"
    },
    "helius": {
      "command": "npx",
      "args": ["-y", "helius-mcp@1.3.0"],
      "env": {
        "HELIUS_API_KEY": "YOUR_HELIUS_API_KEY"
      },
      "_comment": "Optional: Solana on-chain data. Free key: https://helius.dev"
    }
  }
}
